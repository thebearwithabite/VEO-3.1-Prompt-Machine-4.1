{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A VEO production project containing scene plans and assets.",
      "type": "object",
      "properties": {
        "projectName": { "type": "string" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "logEntries": { "type": "array" },
        "apiCallSummary": { "type": "object" },
        "scenePlans": { "type": "array" },
        "lastPrompt": { "type": "object" },
        "assets": { "type": "array" },
        "guidanceFrames": { "type": "array" }
      },
      "required": ["projectName", "userId", "updatedAt"]
    },
    "Shot": {
      "title": "Shot",
      "description": "A single shot within a project, including keyframes and status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sceneName": { "type": "string" },
        "shotNumber": { "type": "number" },
        "description": { "type": "string" },
        "veoPrompt": { "type": "string" },
        "status": { "type": "string" },
        "keyframeImage": { "type": "string" },
        "keyframeHistory": { "type": "array" },
        "veoStatus": { "type": "string" },
        "veoVideoUrl": { "type": "string" }
      },
      "required": ["id", "status"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Root project documents."
    },
    "/projects/{projectId}/shots/{shotId}": {
      "schema": "Shot",
      "description": "Shots belonging to a project."
    }
  }
}
